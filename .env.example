# Environment Variables — Cartum CMS
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ─── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Database ───────────────────────────────────────────────────────────────
# Full PostgreSQL connection string.
# Neon:     postgresql://user:password@host.neon.tech/dbname?sslmode=require
# Supabase: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=

# Database provider. Accepted values: "neon" | "supabase"
DB_PROVIDER=neon

# ─── Authentication (Auth.js v5) ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Full base URL of the application (no trailing slash).
AUTH_URL=http://localhost:3000

# ─── Storage (Cloudflare R2) ─────────────────────────────────────────────────
# Optional. If not set, media upload features are disabled.
# R2_ENDPOINT format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=
R2_PUBLIC_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Optional. Required for password-reset and invitation emails.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
